# Copy: cp .env.example .env — replace with your real Moltbook API key for live threads.
MOLTBOOK_API_KEY=dev-placeholder-replace-with-real-moltbook-key
MOLTBOOK_POLL_INTERVAL_MS=10000
# Default crown hold when POST /api/games omits gameDurationSeconds (ms). Per-round override: JSON body gameDurationSeconds.
GAME_DURATION_MS=60000
PORT=3333
